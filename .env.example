# ============================================================
# RunMotos — variáveis de ambiente
# Copie este arquivo para ".env.local" e preencha com seus dados.
# O ".env.local" NÃO é versionado (está no .gitignore).
# ============================================================

# --- Integração Laquila Dropshipping ---
# Estes valores ficam SOMENTE no servidor. Nunca use o prefixo NEXT_PUBLIC_ aqui,
# senão o segredo vaza para o navegador.
LAQUILA_BASE_URL=https://api-dropshipping.laquila.com.br
LAQUILA_TOKEN=coloque_aqui_o_token_fornecido_pela_laquila
LAQUILA_CNPJ=00000000000000
# cnpj_empresa é o CNPJ da LAQUILA (fixo), não o seu. Padrão já é o da Laquila:
LAQUILA_CNPJ_EMPRESA=03902443000166
# cpf_cnpj_consulta: OPCIONAL. Só preencha (com o SEU CNPJ) se o seu token tiver
# mais de 1 CNPJ vinculado. Vazio = não envia (caso comum, token com 1 CNPJ).
LAQUILA_CPF_CONSULTA=
# Só preencha se a Laquila disser que o token da URL é DIFERENTE do token do corpo:
LAQUILA_URL_TOKEN=
# Wrapper do corpo: "filtro" (foto do suporte) ou "pedido" (PDF). Default: filtro.
LAQUILA_WRAPPER=filtro

# --- OpenAI (categorização automática de produtos) ---
# Chave fica só no servidor (sem NEXT_PUBLIC_). Pegue em https://platform.openai.com/api-keys
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- PayPal (pagamento por cartão) ---
# Secret fica SÓ no servidor. O Client ID é público (vai no front pelo NEXT_PUBLIC_).
PAYPAL_ENV=sandbox            # sandbox | live
NEXT_PUBLIC_PAYPAL_ENV=sandbox # mesmo valor (usado pelo iframe do PayPal Plus no navegador)
PAYPAL_CLIENT_ID=
PAYPAL_SECRET=
NEXT_PUBLIC_PAYPAL_CLIENT_ID= # mesmo Client ID, usado pelo SDK de cartão no navegador

# --- Envia.com (frete) ---
# Token de API. Use o token de sandbox (api-test) para testes.
# Defina o CEP de origem em /admin/configuracoes.
ENVIA_ENV=sandbox            # sandbox | production
ENVIA_TOKEN=

# --- Mercado Pago (PIX) ---
# Access Token fica só no servidor. Use o token de TESTE (TEST-...) no sandbox.
# Painel: Mercado Pago Developers → Suas integrações → Credenciais.
MERCADOPAGO_ACCESS_TOKEN=

# --- E-mail (Gmail SMTP) para o login por código ---
# Use uma SENHA DE APP do Google (precisa de verificação em 2 etapas ativa).
# https://myaccount.google.com/apppasswords
GMAIL_USER=seuemail@gmail.com
GMAIL_APP_PASSWORD=
MAIL_FROM_NAME=RunMotos
# Segredo para assinar a sessão do cliente (gere um aleatório longo):
AUTH_SECRET=

# --- Site ---
# URL pública do site (usada no sitemap, feed do Merchant Center e JSON-LD)
NEXT_PUBLIC_SITE_URL=https://www.runmotos.com.br

# --- Painel administrativo (/admin) ---
# ADMIN_PASSWORD: a senha que você digita para entrar.
# ADMIN_SESSION_TOKEN: um segredo aleatório e longo (o valor do cookie de sessão).
#   Gere um com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_PASSWORD=troque_esta_senha
ADMIN_SESSION_TOKEN=cole_aqui_um_token_aleatorio_longo

# CRON_SECRET: segredo que protege a sincronização de estoque agendada.
#   Use na URL: /api/cron/sync-stock?key=ESTE_VALOR  (agende no Coolify > Scheduled Tasks)
#   Gere um com: node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
CRON_SECRET=cole_aqui_um_segredo_aleatorio
